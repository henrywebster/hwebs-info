<h1>Blog</h1>
<section class="full-width">
    <ul class="unstyled-list">
        {{ range . }}
        <li>
            <article>
                <header>
                    <h2>
                        <a href="/blog/post/{{.slug}}.html">{{.title}}</a>
                    </h2>
                    <time datetime="{{ .date_created }}">{{ (.date_created | time.Parse "2006-01-02 15:04").Format "Jan 02, 2006"  }}</time>
                </header>
            </article>
        </li>
        {{ end }}
    </ul>
</section>
<a href="/blog/feed.xml">Atom Feed</a>
